# ── Airflow 기본 설정 ──────────────────────────────────────────────────────────
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__WEBSERVER__WEB_SERVER_PORT=8080
AIRFLOW__WEBSERVER__DEFAULT_UI_TIMEZONE=Asia/Seoul

# ── 스케줄 설정 (cron) ────────────────────────────────────────────────────────
SCHEDULE_COLLECT=0 2 * * *
SCHEDULE_CITATIONS=0 3 * * *

# ── 수집 설정 ─────────────────────────────────────────────────────────────────
COLLECT_DATE_RANGE_DAYS=1
COLLECT_MAX_RESULTS=100

# ── OpenAI 설정 ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-
TAGGING_MODEL=gpt-4o-mini

# ── 임베딩 설정 ───────────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024

# ── DB 설정 ───────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=research_agent
POSTGRES_USER=postgres
POSTGRES_PASSWORD=