PYTHONPATH=.
LANG=en_US.UTF-8
LC_ALL=en_US.UTF-8

# ── Airflow 기본 설정 ──────────────────────────────────────────────────────────
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__WEBSERVER__WEB_SERVER_PORT=8080
AIRFLOW__WEBSERVER__DEFAULT_UI_TIMEZONE=Asia/Seoul

# ── 스케줄 설정 (cron) ────────────────────────────────────────────────────────
SCHEDULE_COLLECT=0 2 * * *
SCHEDULE_CITATIONS=0 3 * * *

# ── 수집 설정 ─────────────────────────────────────────────────────────────────
# 설정 시: 해당 날짜 ~ 오늘까지 전체 수집 / 미설정 시: 오늘 데이터만 수집 (형식: YYYY-MM-DD)
COLLECT_START_DATE=2025-01-01
# 설정 시: 최신순으로 N개만 수집 / 미설정 시: 전체 수집
COLLECT_MAX_RESULTS=100

# ── 파일 저장 경로 ────────────────────────────────────────────────────────────
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed

# ── OpenAI 설정 ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-
TAGGING_MODEL=gpt-4o-mini

# ── 청킹 설정 ─────────────────────────────────────────────────────────────────
CHUNK_SIZE=512    # 토큰 단위, 오버랩은 10% 자동 적용

# ── LlamaParse 설정 ───────────────────────────────────────────────────────────
LLAMA_CLOUD_API_KEY=llx-

# ── 임베딩 설정 ───────────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
# 로컬(macOS Airflow): cpu  /  로컬(macOS 직접실행): mps  /  운영(Linux): cuda
EMBEDDING_DEVICE=cpu

# ── DB 설정 ───────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=research_agent
POSTGRES_USER=postgres
POSTGRES_PASSWORD=